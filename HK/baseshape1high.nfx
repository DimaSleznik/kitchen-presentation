shiftedsupport=position(base, 0,0, 0,0, 0,-100);
support=size(shiftedsupport,0.6,0.56,0.1,1);

cabinet=combine(support,carcass);

b=subscribe(0.6,mysetsize.xs,support.xs,carcassvent_frontsize.xs);
t=subscribe(0.56,mysetsize.ys,support.ys,drawerbox_usedrawer.t);
h=subscribe(2.035,mysetsize.zs,carcassvent_frontsize.zs);
DRAWCODE=xif(label(\"has_surcharge\",c()),\"xdo(xif(and(not(comparetext(textatt(\\\"prpval\\\",c()),\\\"0\\\")),\\\"equal(content(rank(2,componentatom(c()))),0)\\\"),\\\"xdo(settextatt(\\\\\\\"prpval\\\\\\\",0,c()),SETlabel(0,\\\\\\\"has_surcharge\\\\\\\",c()),sm(componentatom(c())))\\\"))\");
frontoffset=subscribe(0,baseshape1high_legheight.frontoffset, unifront_myheight.selfadjustable);
DRAWCODE=xif(or(unequal(genatt(2,c()),label(\"prpval\",c())),\"unequal(label(\\\"frontoffset\\\",c()),label(\\\"prevfrontoffset\\\",c()))\"),\"xdo(setcs(atombyname(\\\"acarcassvent_frontoffset\\\",componentatom(c()),1)),settextatt(\\\"dz1\\\",xif(label(\\\"frontoffset\\\",c()),\\\"concat(\\\\\\\"-\\\\\\\",string(sub(genatt(2,c()),0.01),0,3))\\\",\\\"\\\\\\\"0\\\\\\\"\\\"),cs()),sm(cs()),setcs(atombyname(\\\"aunifrontlist_unifrontlist\\\",up(c()),1)),setlabel(\\\"refresh\\\",1,cs()),sm(componentatom(c())),SETlabel(genatt(2,c()),\\\"prpval\\\",c()),SETlabel(label(\\\"frontoffset\\\",c()),\\\"prevfrontoffset\\\",c()))\");
