builtinparts=subscribe(11515332, interiortandem_fin2.col, interiortandemduo_fin2.col, geartandemshelfdoor_fin1.col, gearlaundrydoor_fin1.col, interiorcrates_fin2.col, interiorshoes_fin2.col, interiorlaundry_fin2.col, interiorbroom_fin2.col);
tandem=subscribe(0, interiorhigh_shelf.tandem);
midshelves=subscribe(0, interiorhigh_shelf.midshelves);
ventilation=subscribe(0, carcassvent_toppanelinterior.ventilation, carcassvent_toppanelexterior.ventilation, carcassvent_backpanel.ventilation, carcassvent_backpanelrearside.ventilation);
